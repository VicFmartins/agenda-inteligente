@page "/Error"
@using System.Diagnostics

<PageTitle>Erro</PageTitle>

<h1 class="text-danger">Erro</h1>
<h2 class="text-danger">Ocorreu uma falha ao processar sua solicitacao.</h2>

@if (ShowRequestId)
{
    <p>
        <strong>ID da requisicao:</strong> <code>@RequestId</code>
    </p>
}

<h3>Modo de desenvolvimento</h3>
<p>
    Usar o ambiente <strong>Development</strong> exibe detalhes adicionais sobre o erro para fins de depuracao local.
</p>
<p>
    <strong>Esse modo nao deve permanecer habilitado em producao.</strong>
    Ele pode expor informacoes sensiveis de excecoes para usuarios finais.
    Para depuracao local, defina a variavel de ambiente <strong>ASPNETCORE_ENVIRONMENT</strong> como <strong>Development</strong>
    e reinicie a aplicacao.
</p>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
